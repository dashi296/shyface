{
  "name": "shyface",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint src/ app/",
    "test": "jest --forceExit",
    "tsc": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-ml-kit/face-detection": "^2.0.1",
    "@shopify/react-native-skia": "2.4.18",
    "@tanstack/react-query": "^5.94.5",
    "expo": "~55.0.8",
    "expo-crypto": "~55.0.10",
    "expo-file-system": "~55.0.11",
    "expo-image-manipulator": "~55.0.11",
    "expo-image-picker": "^55.0.13",
    "expo-router": "~55.0.7",
    "expo-sqlite": "~55.0.11",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-fast-tflite": "^2.0.0",
    "react-native-reanimated": "^4.2.3",
    "react-native-vision-camera": "^4.7.3",
    "uuid": "^13.0.0",
    "zustand": "^5.0.12"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@shopify/react-native-skia|@sentry/react-native|native-base|react-native-svg|uuid)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    }
  },
  "private": true,
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "~29",
    "@types/react": "~19.2.10",
    "@types/uuid": "^11.0.0",
    "eslint": "9",
    "eslint-config-expo": "^55.0.0",
    "jest": "~29",
    "jest-expo": "^55.0.11",
    "typescript": "~5.9.2"
  },
  "trustedDependencies": [
    "@shopify/react-native-skia"
  ]
}
